{
  "name": "startup_barbarian",
  "description": "Title flow → Barbarian class.",
  "setup": { "seed": 1, "class": "barbarian", "name": "Barb", "difficulty": "easy" },
  "tags": ["smoke", "fast", "startup"],
  "max_seconds": 30,
  "steps": [
    { "step": "assert", "path": "mode",            "op": "==", "value": "adventure" },
    { "step": "assert", "path": "character.class", "op": "==", "value": "barbarian" },
    { "step": "assert", "path": "stats.gold",      "op": ">=", "value": 1 }
  ]
}
