{
  "name": "win_one_castle",
  "description": "Smoke test: drive title flow, BFS to a foot-reachable villain castle in continentia, auto-combat the siege.",
  "setup": {
    "seed": 42,
    "class": "knight",
    "name": "Bot",
    "difficulty": "easy",
    "auto_combat": true
  },
  "tags": ["smoke", "castle", "combat"],
  "max_seconds": 90,
  "steps": [
    { "step": "assert_overworld" },
    { "step": "assert",      "path": "character.class",          "op": "==", "value": "knight" },
    { "step": "assert",      "path": "character.name",           "op": "==", "value": "Bot" },
    { "step": "assert",      "path": "position.zone",            "op": "==", "value": "continentia" },
    { "step": "assert",      "path": "stats.gold",               "op": ">=", "value": 1 },
    { "step": "assert",      "path": "stats.leadership_current", "op": ">=", "value": 1 },

    { "step": "snapshot_baseline", "as": "base" },

    { "step": "let_villain_castle_in", "name": "V", "zone": "continentia" },

    { "step": "bfs_to_replan", "ref": "V", "max_hops": 12, "on_foe": "auto_combat", "on_chest": "take_a", "on_dialog": "drain" },

    { "step": "expect_prompt", "kind": "siege" },
    { "step": "resolve_combat", "press_y": true },
    { "step": "drain_dialogs", "max": 8 },

    { "step": "assert_overworld" },
    { "step": "assert_ge", "path": "stats.score", "ref_baseline": "base", "field": "score" }
  ]
}
