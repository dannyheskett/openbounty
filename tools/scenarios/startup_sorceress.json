{
  "name": "startup_sorceress",
  "description": "Title flow → Sorceress class. Confirms knows_magic at rank 0 (per ClassDef).",
  "setup": { "seed": 1, "class": "sorceress", "name": "Sera", "difficulty": "easy" },
  "tags": ["smoke", "fast", "startup"],
  "max_seconds": 30,
  "steps": [
    { "step": "assert", "path": "mode",            "op": "==", "value": "adventure" },
    { "step": "assert", "path": "character.class", "op": "==", "value": "sorceress" },
    { "step": "assert", "path": "stats.knows_magic", "op": "==", "value": true }
  ]
}
