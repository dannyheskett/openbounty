{
  "name": "cheat_magic_spells",
  "description": "F10 → M (boost magic) + F10 → U (full spellbook).",
  "setup": { "seed": 1, "class": "knight", "name": "Bot", "difficulty": "easy" },
  "tags": ["smoke", "fast", "cheat", "spells"],
  "max_seconds": 30,
  "steps": [
    { "step": "cheat", "letter": "M" },
    { "step": "cheat", "letter": "U" },
    { "step": "assert", "path": "stats.spell_power", "op": ">=", "value": 1 },
    { "step": "assert", "path": "stats.max_spells",  "op": ">=", "value": 1 }
  ]
}
