{
  "name": "foe_hostile_attack",
  "description": "Walk to villain castle (which always has a foe encounter on the path). Verify hostile foe combat fires and resolves. Same path as win_one_castle but checks followers_killed went up.",
  "setup": { "seed": 42, "class": "knight", "name": "Bot", "difficulty": "easy", "auto_combat": true },
  "tags": ["smoke", "foe", "combat"],
  "max_seconds": 90,
  "steps": [
    { "step": "snapshot_baseline", "as": "base" },
    { "step": "let_villain_castle_in", "name": "V", "zone": "continentia" },
    { "step": "bfs_to_replan", "ref": "V", "max_hops": 12, "on_foe": "auto_combat", "on_chest": "take_a", "on_dialog": "drain" },
    { "step": "drain_dialogs", "max": 8 },
    { "step": "assert", "path": "stats.game_over", "op": "==", "value": false },
    { "step": "assert_ge", "path": "stats.followers_killed", "ref_baseline": "base", "field": "killed" }
  ]
}
